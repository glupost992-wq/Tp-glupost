    screenGui.ResetOnSpawn = false
    hudFrame = Instance.new("Frame")
    hudFrame.Parent = screenGui
    hudFrame.Size = UDim2.new(0,180,0,60)
    hudFrame.Position = UDim2.new(settings.hudPos.scaleX, settings.hudPos.offX, settings.hudPos.scaleY, settings.hudPos.offY)
    hudFrame.BackgroundColor3 = Color3.fromRGB(settings.hudBgColor[1], settings.hudBgColor[2], settings.hudBgColor[3])
    hudFrame.BackgroundTransparency = settings.hudTransparency
    hudFrame.BorderSizePixel = 1
    hudFrame.BorderColor3 = Color3.fromRGB(100,100,100)
    hudFrame.Active = true
    hudFrame.Draggable = true
    Instance.new("UICorner", hudFrame).CornerRadius = UDim.new(0,8)
    local title = Instance.new("TextLabel", hudFrame)
    title.Size = UDim2.new(1,0,0,20)
    title.BackgroundTransparency = 1
    title.Text = "📍 Координаты"
    title.TextColor3 = Color3.fromRGB(200,200,200)
    title.TextSize = 12
    hudLabel = Instance.new("TextLabel", hudFrame)
    hudLabel.Size = UDim2.new(1,0,0,35)
    hudLabel.Position = UDim2.new(0,0,0,22)
    hudLabel.BackgroundTransparency = 1
    hudLabel.Text = "X: 0\nY: 0\nZ: 0"
    hudLabel.TextColor3 = Color3.fromRGB(settings.hudColor[1], settings.hudColor[2], settings.hudColor[3])
    hudLabel.TextSize = 14
    hudLabel.Font = Enum.Font.GothamBold
    hudLabel.TextXAlignment = Enum.TextXAlignment.Center
    hudFrame:GetPropertyChangedSignal("Position"):Connect(function()
        if hudFrame then
            settings.hudPos = {scaleX = hudFrame.Position.X.Scale, offX = hudFrame.Position.X.Offset, scaleY = hudFrame.Position.Y.Scale, offY = hudFrame.Position.Y.Offset}
            saveSettings()
        end
    end)
    updateHUD()
    if not hudUpdateConn then
        hudUpdateConn = RunService.Heartbeat:Connect(updateHUD)
    end
end

local function toggleHUD()
    settings.showHUD = not settings.showHUD
    if settings.showHUD then createHUD() else if hudFrame then hudFrame:Destroy(); hudFrame = nil end; if hudUpdateConn then hudUpdateConn:Disconnect(); hudUpdateConn = nil end end
    saveSettings()
end

-- ========== ФУНКЦИИ ДЛЯ ПОСТРОЕНИЯ GUI ==========
local function setupScrollingFrame(frame)
    -- Настраивает ScrollingFrame для корректной прокрутки
    local layout = frame:FindFirstChildOfClass("UIListLayout")
    if not layout then
        layout = Instance.new("UIListLayout", frame)
        layout.Padding = UDim.new(0,8)
        layout.SortOrder = Enum.SortOrder.LayoutOrder
    end
    local function updateCanvas()
        frame.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y + 20)
    end
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)
    task.defer(updateCanvas)
    return layout
end

