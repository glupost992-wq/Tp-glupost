        saveSettings()
    end
    rBox.FocusLost:Connect(function() update(tonumber(rBox.Text), tonumber(gBox.Text), tonumber(bBox.Text)) end)
    gBox.FocusLost:Connect(function() update(tonumber(rBox.Text), tonumber(gBox.Text), tonumber(bBox.Text)) end)
    bBox.FocusLost:Connect(function() update(tonumber(rBox.Text), tonumber(gBox.Text), tonumber(bBox.Text)) end)
