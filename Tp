hudBgColor = Window.Flags.hudBgColor or hudBgColor
hudTransparency = Window.Flags.hudTransparency or hudTransparency

-- Восстановление последних координат
lastCoords.x = Window.Flags.tpX or "0"
lastCoords.y = Window.Flags.tpY or "100"
lastCoords.z = Window.Flags.tpZ or "0"

-- Запуск HUD
toggleHUD(showHUD)

-- Автозапуск режимов
if Window.Flags.autoLoopEnabled then startAuto() end
if Window.Flags.followEnabled then startFollow() end

sendNotify("✅ Готово", "Телепорт v7.7 загружен. Меню: RightShift", 3)
