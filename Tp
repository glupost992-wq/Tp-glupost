-- Звуки
local ENDERMAN_SOUND_ID = "rbxassetid://93826112721753"
local CLICK_SOUND_ID = "rbxassetid://9120383236"
local EVENT_DEATH_SOUND_ID = "rbxassetid://9120378845"
local EVENT_STOP_SOUND_ID = "rbxassetid://9120379812"

-- Сохранение/загрузка
local configFolder = "TeleportScript"
local configFile = "Settings.json"

local function saveSettings()
    if not isfolder then return end
    if not isfolder(configFolder) then makefolder(configFolder) end
    local data = {}
    for k,v in pairs(settings) do data[k] = v end
    writefile(configFolder.."/"..configFile, game:GetService("HttpService"):JSONEncode(data))
end

local function loadSettings()
    if not isfile then return end
    if isfile(configFolder.."/"..configFile) then
        local success, data = pcall(function()
            return game:GetService("HttpService"):JSONDecode(readfile(configFolder.."/"..configFile))
        end)
        if success and data then
            for k,v in pairs(data) do settings[k] = v end
        end
    end
end

-- ========== ВСПОМОГАТЕЛЬНЫЕ ==========
local function playSound(id, volume)
    if not settings.effectsEnabled then return end
    local sound = Instance.new("Sound")
    sound.SoundId = id
    sound.Volume = (volume or 0.5) * settings.effectIntensity
    sound.Parent = LP.Character or LP
    sound:Play()
    game:GetService("Debris"):AddItem(sound, 1)
end

local function playClickSound()
    if settings.clickSoundEnabled then playSound(CLICK_SOUND_ID, 0.2) end
end

local function playEventStopSound()
    if settings.eventSoundEnabled then playSound(EVENT_STOP_SOUND_ID, 0.5) end
end

local function playEventDeathSound()
    if settings.eventSoundEnabled then playSound(EVENT_DEATH_SOUND_ID, 0.5) end
end

local function animateButton(btn)
    local originalSize = btn.Size
    TweenService:Create(btn, TweenInfo.new(0.08, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = originalSize * 0.95}):Play()
    task.wait(0.05)
    TweenService:Create(btn, TweenInfo.new(0.08, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = originalSize}):Play()
end

local function updateWindowTitle()
    if not mainFrame then return end
    local titleBar = mainFrame:FindFirstChild("TitleBar")
    if not titleBar then return end
    local titleLabel = titleBar:FindFirstChild("TitleLabel")
    if not titleLabel then return end
    local indicators = ""
    if autoActive then indicators = indicators .. " 🔄" end
    if followActive then indicators = indicators .. " 👥" end
    if loopABActive then indicators = indicators .. " 🔁" end
    titleLabel.Text = "✨ Телепорт v10.3" .. indicators
end

-- ========== ТЕЛЕПОРТ ==========
local function teleport(pos)
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    hrp.CFrame = CFrame.new(pos)
    if settings.effectsEnabled then
        playSound(ENDERMAN_SOUND_ID, 0.5)
        local pe = Instance.new("ParticleEmitter")
        pe.Parent = hrp
        pe.Rate = 300 * settings.effectIntensity
        pe.Lifetime = NumberRange.new(0.6)
        pe.SpreadAngle = Vector2.new(360,360)
        pe.Speed = NumberRange.new(8)
        pe.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,0.7), NumberSequenceKeypoint.new(1,1)})
        pe.Color = ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(180,80,255)), ColorSequenceKeypoint.new(0.5,Color3.fromRGB(100,0,200)), ColorSequenceKeypoint.new(1,Color3.fromRGB(60,0,120))})
        pe.Size = NumberSequence.new(1.5)
        pe.Rotation = NumberRange.new(0,360)
        pe.Acceleration = Vector3.new(0,-5,0)
        pe.Enabled = true
        task.wait(0.05)
        pe.Enabled = false
        game:GetService("Debris"):AddItem(pe,1)
        if settings.effectIntensity > 0.5 then
            local flash = Instance.new("Frame")
            flash.Size = UDim2.new(2,0,2,0)
            flash.Position = UDim2.new(-0.5,0,-0.5,0)
            flash.BackgroundColor3 = Color3.fromRGB(100,0,150)
            flash.BackgroundTransparency = 0.6
            flash.BorderSizePixel = 0
            local gui = LP:FindFirstChild("PlayerGui")
            if gui then
                flash.Parent = gui
                flash.ZIndex = 999
                TweenService:Create(flash, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
                game:GetService("Debris"):AddItem(flash,0.3)
            end
        end
    end
end

local function tpToCoords()
    local x = tonumber(settings.tpX) or 0
    local y = tonumber(settings.tpY) or 50
    local z = tonumber(settings.tpZ) or 0
    teleport(Vector3.new(x,y,z))
end

