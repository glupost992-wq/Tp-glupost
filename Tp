--[[
    Телепорт-скрипт v7.2 (Rayfield)
    - Мгновенный ТП по координатам
    - Дом (установить / вернуться)
    - Автоцикл (хаотичные телепорты)
    - ТП к игроку + НЕПРЕРЫВНОЕ СЛЕДОВАНИЕ (пока цель жива)
    - Полное сохранение настроек
--]]

if not _G.Rayfield then
    local RayfieldSource = game:HttpGet("https://raw.githubusercontent.com/SiriusSoftwareLtd/Rayfield/main/source.lua")
    _G.Rayfield = loadstring(RayfieldSource)()
end
local Rayfield = _G.Rayfield

local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local UIS = game:GetService("UserInputService")
local Mouse = LP:GetMouse()

local homePos = nil
local autoActive = false
local autoCoroutine = nil
local followActive = false
local followCoroutine = nil
local selectedPlayer = ""

local settings = {
    randXmin = -1000,
    randXmax = 1000,
    randYmin = 50,
    randYmax = 200,
    randZmin = -1000,
    randZmax = 1000,
    loopDelay = 1.0,
    returnEvery = 3,
    followDistance = 4,   -- дистанция рядом с игроком
    followInterval = 0.6, -- интервал между телепортами
}

local function teleport(pos)
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.CFrame = CFrame.new(pos) end
end

local function sendNotify(title, content, duration)
    Rayfield:Notify({Title = title or "Телепорт", Content = content or "", Duration = duration or 2})
end

local function tpToCoords(x, y, z)
    x = tonumber(x) or 0
    y = tonumber(y) or 50
    z = tonumber(z) or 0
    teleport(Vector3.new(x, y, z))
    sendNotify("Телепорт", string.format("(%.0f, %.0f, %.0f)", x, y, z))
end

local function setHome()
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        homePos = hrp.Position
        sendNotify("Дом", "Сохранён: " .. tostring(homePos))
    else
        sendNotify("Ошибка", "Не удалось сохранить дом", 3)
    end
end

local function goHome()
    if homePos then
        teleport(homePos)
        sendNotify("Дом", "Возврат")
    else
        sendNotify("Ошибка", "Дом не установлен", 3)
    end
end

local function randomPos()
    local x = math.random(settings.randXmin, settings.randXmax)
    local y = math.random(settings.randYmin, settings.randYmax)
    local z = math.random(settings.randZmin, settings.randZmax)
    return Vector3.new(x, y, z)
end

local stepCount = 0
local function autoStep()
    local target = randomPos()
    teleport(target)
    stepCount = stepCount + 1
    if settings.returnEvery > 0 and homePos and stepCount % settings.returnEvery == 0 then
        teleport(homePos)
        sendNotify("Автоцикл", "Возврат домой (шаг " .. stepCount .. ")")
    else
        sendNotify("Автоцикл", string.format("#%d → (%.0f, %.0f, %.0f)", stepCount, target.X, target.Y, target.Z))
    end
end

local function startAuto()
    if autoActive then return end
    autoActive = true
    stepCount = 0
    sendNotify("Автоцикл", "Запущен")
    autoCoroutine = task.spawn(function()
        while autoActive do
            autoStep()
            task.wait(settings.loopDelay)
        end
    end)
end

local function stopAuto()
    if not autoActive then return end
    autoActive = false
    if autoCoroutine then task.cancel(autoCoroutine); autoCoroutine = nil end
    sendNotify("Автоцикл", "Остановлен")
end

-- ========== НОВЫЙ РЕЖИМ: СЛЕДОВАНИЕ ЗА ИГРОКОМ ==========
local function stopFollow()
    if followActive then
        followActive = false
        if followCoroutine then task.cancel(followCoroutine); followCoroutine = nil end
        sendNotify("Следование", "Остановлено")
    end
end

local function startFollow()
    if selectedPlayer == "" or selectedPlayer == "(нет игроков)" then
        sendNotify("Ошибка", "Сначала выберите игрока", 2)
        return
    end
    if followActive then stopFollow() end
    followActive = true
    sendNotify("Следование", "Включено для " .. selectedPlayer)
    followCoroutine = task.spawn(function()
        while followActive do
            local target = Players:FindFirstChild(selectedPlayer)
            if not target or not target.Character then
                sendNotify("Следование", "Игрок покинул игру или исчез", 2)
                stopFollow()
                break
            end
            local hrp = target.Character:FindFirstChild("HumanoidRootPart")
            local hum = target.Character:FindFirstChildOfClass("Humanoid")
            if not hrp or not hum then
                task.wait(0.5)
                continue
            end
            if hum.Health <= 0 then
                sendNotify("Следование", "Игрок умер, следование прекращено", 2)
                stopFollow()
                break
            end
            -- Телепортируем рядом с игроком (не внутрь)
            local pos = hrp.Position
            -- Добавляем случайное небольшое смещение, чтобы не застревать
            local offset = Vector3.new(
                (math.random() - 0.5) * settings.followDistance,
                0,
                (math.random() - 0.5) * settings.followDistance
            )
            teleport(pos + offset)
            task.wait(settings.followInterval)
        end
    end)
end

local function teleportToPlayerOnce()  -- старая функция "телепорт один раз"
    if selectedPlayer == "" or selectedPlayer == "(нет игроков)" then
        sendNotify("Ошибка", "Нет выбранного игрока", 2)
        return
    end
    local target = Players:FindFirstChild(selectedPlayer)
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local pos = target.Character.HumanoidRootPart.Position
        local offset = Vector3.new(2, 0, 2)  -- рядом, но не внутрь
        teleport(pos + offset)
        sendNotify("Телепорт", "К игроку " .. target.DisplayName .. " (один раз)")
    else
        sendNotify("Ошибка", "Игрок не найден или нет персонажа", 3)
    end
end

local function getPlayerList()
    local names = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LP then
            table.insert(names, plr.Name)
        end
    end
    table.sort(names)
    if #names == 0 then names = {"(нет игроков)"} end
    return names
end

-- ========== GUI ==========
local Window = Rayfield:CreateWindow({
    Name = "Телепорт v7.2",
    ConfigurationSaving = { Enabled = true, FolderName = "TeleportScript", FileName = "Settings" },
    KeySystem = false,
})

-- Вкладка "Телепорт"
local tpTab = Window:CreateTab("Телепорт", 4483362458)
tpTab:CreateInput({ Name = "X", CurrentValue = "0", Flag = "tpX", Callback = function() end })
tpTab:CreateInput({ Name = "Y", CurrentValue = "100", Flag = "tpY", Callback = function() end })
tpTab:CreateInput({ Name = "Z", CurrentValue = "0", Flag = "tpZ", Callback = function() end })
tpTab:CreateKeybind({ Name = "ТП по координатам", CurrentKeybind = "T", Flag = "tpBind", Callback = function()
    tpToCoords(Window.Flags.tpX, Window.Flags.tpY, Window.Flags.tpZ)
end })
tpTab:CreateKeybind({ Name = "Установить дом", CurrentKeybind = "H", Callback = setHome })
tpTab:CreateKeybind({ Name = "Вернуться домой", CurrentKeybind = "G", Callback = goHome })

-- Вкладка "Автоцикл"
local autoTab = Window:CreateTab("Автоцикл", 4483362458)
autoTab:CreateToggle({ Name = "Включить автоцикл", Flag = "autoLoopEnabled", Callback = function(val)
    if val then startAuto() else stopAuto() end
end })
autoTab:CreateSlider({ Name = "X min", Range = {-10000,10000}, Increment=10, Flag="randXmin", Callback=function(v) settings.randXmin=v end })
autoTab:CreateSlider({ Name = "X max", Range = {-10000,10000}, Increment=10, Flag="randXmax", Callback=function(v) settings.randXmax=v end })
autoTab:CreateSlider({ Name = "Y min", Range = {0,500}, Increment=5, Flag="randYmin", Callback=function(v) settings.randYmin=v end })
autoTab:CreateSlider({ Name = "Y max", Range = {0,500}, Increment=5, Flag="randYmax", Callback=function(v) settings.randYmax=v end })
autoTab:CreateSlider({ Name = "Z min", Range = {-10000,10000}, Increment=10, Flag="randZmin", Callback=function(v) settings.randZmin=v end })
autoTab:CreateSlider({ Name = "Z max", Range = {-10000,10000}, Increment=10, Flag="randZmax", Callback=function(v) settings.randZmax=v end })
autoTab:CreateSlider({ Name = "Задержка (сек)", Range = {0.2,10}, Increment=0.1, Flag="loopDelay", Callback=function(v) settings.loopDelay=v end })
autoTab:CreateInput({ Name = "Возврат каждые N", CurrentValue="3", Flag="returnEvery", Callback=function(v) settings.returnEvery=tonumber(v) or 0 end })

-- Вкладка "Игроки"
local playerTab = Window:CreateTab("Игроки", 4483362458)
local playerDropdown = playerTab:CreateDropdown({ Name = "Выберите игрока", Values = getPlayerList(), Flag = "targetPlayer", Callback = function(opt) selectedPlayer = opt end })
playerTab:CreateButton({ Name = "Обновить список", Callback = function()
    playerDropdown:Refresh(getPlayerList())
    if #getPlayerList()>0 and selectedPlayer=="" then selectedPlayer=getPlayerList()[1]; playerDropdown:SetValue(selectedPlayer) end
end })
playerTab:CreateKeybind({ Name = "ТП к игроку (один раз)", CurrentKeybind = "C", Callback = teleportToPlayerOnce })
playerTab:CreateToggle({ Name = "Следовать за игроком (пока жив)", Flag = "followEnabled", Callback = function(val)
    if val then startFollow() else stopFollow() end
end })
playerTab:CreateSlider({ Name = "Дальность следования", Range = {2,10}, Increment=0.5, CurrentValue=settings.followDistance, Flag="followDistance", Callback=function(v) settings.followDistance=v end })
playerTab:CreateSlider({ Name = "Интервал следования (сек)", Range = {0.3,2}, Increment=0.1, CurrentValue=settings.followInterval, Flag="followInterval", Callback=function(v) settings.followInterval=v end })

-- Вкладка UI
local uiTab = Window:CreateTab("UI", 4483362458)
uiTab:CreateKeybind({ Name = "Открыть меню", CurrentKeybind = "RightShift", Flag = "menuBind", Callback = function() end })

Rayfield:LoadConfiguration()
task.wait(0.5)
settings.randXmin = Window.Flags.randXmin or settings.randXmin
settings.randXmax = Window.Flags.randXmax or settings.randXmax
settings.randYmin = Window.Flags.randYmin or settings.randYmin
settings.randYmax = Window.Flags.randYmax or settings.randYmax
settings.randZmin = Window.Flags.randZmin or settings.randZmin
settings.randZmax = Window.Flags.randZmax or settings.randZmax
settings.loopDelay = Window.Flags.loopDelay or settings.loopDelay
settings.returnEvery = tonumber(Window.Flags.returnEvery) or settings.returnEvery
settings.followDistance = Window.Flags.followDistance or settings.followDistance
settings.followInterval = Window.Flags.followInterval or settings.followInterval
selectedPlayer = Window.Flags.targetPlayer or ""
if Window.Flags.autoLoopEnabled then startAuto() end
if Window.Flags.followEnabled then startFollow() end

sendNotify("Готово", "Телепорт-скрипт v7.2 загружен. Меню: RightShift", 3)
