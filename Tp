    teleport(Vector3.new(0,50,0))
end

local function tpToSpawn()
    local spawn = Workspace:FindFirstChild("SpawnLocation")
    if spawn then teleport(spawn.Position + Vector3.new(0,3,0)) end
end

local function setHome()
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if hrp then homePos = hrp.Position end
end

local function goHome()
    if homePos then teleport(homePos) end
end

-- ========== АВТОЦИКЛ ==========
local function randomPos()
    return Vector3.new(
        math.random(settings.randXmin, settings.randXmax),
        math.random(settings.randYmin, settings.randYmax),
        math.random(settings.randZmin, settings.randZmax)
    )
end

local function autoStep()
    teleport(randomPos())
    stepCount = stepCount + 1
    if settings.returnEvery > 0 and homePos and stepCount % settings.returnEvery == 0 then
        teleport(homePos)
    end
end

local function startAuto()
    if autoActive then return end
    autoActive = true
    stepCount = 0
    autoCoroutine = task.spawn(function()
        while autoActive do
            autoStep()
            task.wait(settings.loopDelay)
        end
    end)
    settings.autoLoopEnabled = true
    updateWindowTitle()
    saveSettings()
end

local function stopAuto(noSound)
    if not autoActive then return end
    autoActive = false
    if autoCoroutine then task.cancel(autoCoroutine); autoCoroutine = nil end
    if not noSound then playEventStopSound() end
    settings.autoLoopEnabled = false
    updateWindowTitle()
    saveSettings()
end

-- ========== СЛЕДОВАНИЕ ==========
local function stopFollow(noSound)
    if followActive then
        followActive = false
        if followCoroutine then task.cancel(followCoroutine); followCoroutine = nil end
        if not noSound then playEventStopSound() end
        settings.followEnabled = false
        updateWindowTitle()
        saveSettings()
    end
end

local function startFollow()
    if selectedPlayer == "" then return end
    if followActive then stopFollow(true) end
    followActive = true
    settings.followEnabled = true
    updateWindowTitle()
    saveSettings()
    followCoroutine = task.spawn(function()
        while followActive do
            local target = Players:FindFirstChild(selectedPlayer)
            if not target or not target.Character then stopFollow(true); break end
            local hrp = target.Character:FindFirstChild("HumanoidRootPart")
            local hum = target.Character:FindFirstChildOfClass("Humanoid")
            if not hrp or not hum then task.wait(0.5); continue end
            if hum.Health <= 0 then
                playEventDeathSound()
                stopFollow(true)
                break
            end
            local pos = hrp.Position
            local offset = Vector3.new((math.random()-0.5)*settings.followDistance, 0, (math.random()-0.5)*settings.followDistance)
            teleport(pos+offset)
            task.wait(settings.followInterval)
        end
    end)
end

local function teleportToPlayerOnce()
    local target = Players:FindFirstChild(selectedPlayer)
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        teleport(target.Character.HumanoidRootPart.Position + Vector3.new(2,0,2))
    end
end

-- ========== ЦИКЛ A-B ==========
local function setPointA()
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if hrp then pointA = hrp.Position end
end

local function setPointB()
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if hrp then pointB = hrp.Position end
end

local function swapAB()
    if pointA and pointB then pointA, pointB = pointB, pointA end
end

local function stopLoopAB(noSound)
    if loopABActive then
        loopABActive = false
        if loopABCoroutine then task.cancel(loopABCoroutine); loopABCoroutine = nil end
        if not noSound then playEventStopSound() end
        updateWindowTitle()
    end
end

local function startLoopAB()
    if not pointA or not pointB then return end
    if loopABActive then stopLoopAB(true) end
    loopABActive = true
    currentABTarget = "A"
    updateWindowTitle()
    loopABCoroutine = task.spawn(function()
        while loopABActive do
            if currentABTarget == "A" then teleport(pointA); currentABTarget = "B"
            else teleport(pointB); currentABTarget = "A" end
            task.wait(settings.abLoopDelay)
        end
    end)
end

-- ========== КОПИРОВАНИЕ КООРДИНАТ ==========
local function copyCurrentCoords()
