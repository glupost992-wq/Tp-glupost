-- ========== ПЕРЕМЕННЫЕ ==========
local homePos = nil
local autoActive = false
local autoCoroutine = nil
local followActive = false
local followCoroutine = nil
local selectedPlayer = ""

local pointA = nil
local pointB = nil
local loopABActive = false
local loopABCoroutine = nil
local currentABTarget = "A"

local effectsEnabled = true
local effectIntensity = 1

-- Сохранение ID звука и текстуры для удобства (их можно менять в будущем)
local ENDERMAN_SOUND_ID = "rbxassetid://93826112721753"
local PARTICLE_TEXTURE_ID = "rbxassetid://0"  -- 0 значит стандартная текстура, но мы настроим цвет

local settings = {
    randXmin = -1000,
    randXmax = 1000,
    randYmin = 50,
    randYmax = 200,
    randZmin = -1000,
    randZmax = 1000,
    loopDelay = 1.0,
    returnEvery = 3,
    followDistance = 4,
    followInterval = 0.6,
}

-- ========== ОСНОВНЫЕ ФУНКЦИИ ==========
local function teleport(pos)
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Сохраняем старую позицию для эффектов (если нужно)
    local oldPos = hrp.Position
    
    -- Выполняем телепорт
    hrp.CFrame = CFrame.new(pos)
    
    -- Визуальные и звуковые эффекты
    if effectsEnabled then
        -- 1. Звук Эндермена
        local sound = Instance.new("Sound")
        sound.SoundId = ENDERMAN_SOUND_ID
        sound.Volume = 0.5 * effectIntensity
        sound.Parent = hrp
        sound:Play()
        game:GetService("Debris"):AddItem(sound, 1)
        
        -- 2. Частицы, как у Эндермена (фиолетовая дымка)
        -- Создаем временный эмиттер
        local particleEmitter = Instance.new("ParticleEmitter")
        particleEmitter.Parent = hrp
        
        -- Настройки частиц для имитации эффекта Эндермена
        particleEmitter.Texture = PARTICLE_TEXTURE_ID  -- Стандартная текстура
        particleEmitter.Rate = 300 * effectIntensity  -- Много частиц
        particleEmitter.Lifetime = NumberRange.new(0.6)  -- Живут 0.6 секунды
        particleEmitter.SpreadAngle = Vector2.new(360, 360)  -- Летят во все стороны
        particleEmitter.VelocityInheritance = 0
        particleEmitter.Speed = NumberRange.new(8)  -- Средняя скорость
        particleEmitter.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.7),  -- В начале почти непрозрачные
            NumberSequenceKeypoint.new(1, 1),    -- В конце полностью прозрачные
        })
        -- Цвета, как у портала Эндермена: от ярко-фиолетового до темно-фиолетового
        particleEmitter.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(180, 80, 255)), -- Яркий фиолетовый
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(100, 0, 200)), -- Темный фиолетовый
            ColorSequenceKeypoint.new(1, Color3.fromRGB(60, 0, 120)),    -- Почти черный
        })
        particleEmitter.Size = NumberSequence.new(1.5)  -- Размер частиц
        particleEmitter.Rotation = NumberRange.new(0, 360)  -- Случайный поворот
        -- Добавляем гравитацию, чтобы частицы "падали", как дым
        particleEmitter.Acceleration = Vector3.new(0, -5, 0)
        
        -- Активируем и сразу останавливаем эмиттер, чтобы он выпустил один импульс частиц
        particleEmitter.Enabled = true
        task.wait(0.05)
        particleEmitter.Enabled = false
        
        -- Удаляем эмиттер через секунду, чтобы он не засорял память
        game:GetService("Debris"):AddItem(particleEmitter, 1)
        
        -- 3. Небольшая визуальная вспышка на экране (опционально)
        local flash = Instance.new("Frame")
        flash.Size = UDim2.new(2, 0, 2, 0)
        flash.Position = UDim2.new(-0.5, 0, -0.5, 0)
        flash.BackgroundColor3 = Color3.fromRGB(100, 0, 150) -- Фиолетовый цвет вспышки
        flash.BackgroundTransparency = 0.6
        flash.BorderSizePixel = 0
        local gui = LP:FindFirstChild("PlayerGui")
        if gui then
            flash.Parent = gui
            flash.ZIndex = 999
            TweenService:Create(flash, TweenInfo.new(0.2, Enum.EasingStyle.Linear), {BackgroundTransparency = 1}):Play()
            game:GetService("Debris"):AddItem(flash, 0.3)
        end
    end
end

local function sendNotify(title, content, duration)
    Rayfield:Notify({Title = title or "Телепорт", Content = content or "", Duration = duration or 2})
end

local function tpToCoords(x, y, z)
    x = tonumber(x) or 0
    y = tonumber(y) or 50
    z = tonumber(z) or 0
    teleport(Vector3.new(x, y, z))
    sendNotify("Телепорт", string.format("(%.0f, %.0f, %.0f)", x, y, z))
end

local function setHome()
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        homePos = hrp.Position
        sendNotify("Дом", "Сохранён: " .. tostring(homePos))
    else
        sendNotify("Ошибка", "Не удалось сохранить дом", 3)
    end
end

local function goHome()
    if homePos then
        teleport(homePos)
        sendNotify("Дом", "Возврат")
    else
        sendNotify("Ошибка", "Дом не установлен", 3)
    end
end

-- Автоцикл (случайные точки)
local function randomPos()
    local x = math.random(settings.randXmin, settings.randXmax)
    local y = math.random(settings.randYmin, settings.randYmax)
    local z = math.random(settings.randZmin, settings.randZmax)
    return Vector3.new(x, y, z)
end

local stepCount = 0
local function autoStep()
    local target = randomPos()
    teleport(target)
    stepCount = stepCount + 1
    if settings.returnEvery > 0 and homePos and stepCount % settings.returnEvery == 0 then
        teleport(homePos)
        sendNotify("Автоцикл", "Возврат домой (шаг " .. stepCount .. ")")
    else
        sendNotify("Автоцикл", string.format("#%d → (%.0f, %.0f, %.0f)", stepCount, target.X, target.Y, target.Z))
    end
end

local function startAuto()
    if autoActive then return end
    autoActive = true
    stepCount = 0
    sendNotify("Автоцикл", "Запущен")
    autoCoroutine = task.spawn(function()
        while autoActive do
            autoStep()
            task.wait(settings.loopDelay)
        end
    end)
end

local function stopAuto()
    if not autoActive then return end
    autoActive = false
    if autoCoroutine then task.cancel(autoCoroutine); autoCoroutine = nil end
    sendNotify("Автоцикл", "Остановлен")
end

-- ========== РЕЖИМ СЛЕДОВАНИЯ ==========
local function stopFollow()
    if followActive then
        followActive = false
        if followCoroutine then task.cancel(followCoroutine); followCoroutine = nil end
        sendNotify("Следование", "Остановлено")
    end
end

local function startFollow()
    if selectedPlayer == "" or selectedPlayer == "(нет игроков)" then
        sendNotify("Ошибка", "Сначала выберите игрока", 2)
        return
    end
    if followActive then stopFollow() end
    followActive = true
    sendNotify("Следование", "Включено для " .. selectedPlayer)
    followCoroutine = task.spawn(function()
        while followActive do
            local target = Players:FindFirstChild(selectedPlayer)
            if not target or not target.Character then
                sendNotify("Следование", "Игрок покинул игру", 2)
                stopFollow()
                break
            end
            local hrp = target.Character:FindFirstChild("HumanoidRootPart")
            local hum = target.Character:FindFirstChildOfClass("Humanoid")
            if not hrp or not hum then
                task.wait(0.5)
                continue
            end
            if hum.Health <= 0 then
                sendNotify("Следование", "Игрок умер, следование прекращено", 2)
                stopFollow()
                break
            end
            local pos = hrp.Position
            local offset = Vector3.new((math.random() - 0.5) * settings.followDistance, 0, (math.random() - 0.5) * settings.followDistance)
            teleport(pos + offset)
            task.wait(settings.followInterval)
        end
    end)
end

local function teleportToPlayerOnce()
    if selectedPlayer == "" or selectedPlayer == "(нет игроков)" then
        sendNotify("Ошибка", "Нет выбранного игрока", 2)
        return
    end
    local target = Players:FindFirstChild(selectedPlayer)
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local pos = target.Character.HumanoidRootPart.Position
        local offset = Vector3.new(2, 0, 2)
        teleport(pos + offset)
        sendNotify("Телепорт", "К игроку " .. target.DisplayName .. " (один раз)")
    else
        sendNotify("Ошибка", "Игрок не найден или нет персонажа", 3)
    end
end

-- ========== ЦИКЛ A-B ==========
local function setPointA()
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        pointA = hrp.Position
        sendNotify("Цикл A-B", "Точка A сохранена: " .. tostring(pointA))
    else
        sendNotify("Ошибка", "Не удалось сохранить точку A", 3)
    end
end

local function setPointB()
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        pointB = hrp.Position
        sendNotify("Цикл A-B", "Точка B сохранена: " .. tostring(pointB))
    else
        sendNotify("Ошибка", "Не удалось сохранить точку B", 3)
    end
end

local function stopLoopAB()
    if loopABActive then
        loopABActive = false
        if loopABCoroutine then task.cancel(loopABCoroutine); loopABCoroutine = nil end
        sendNotify("Цикл A-B", "Остановлен")
    end
end

local function startLoopAB()
    if not pointA or not pointB then
        sendNotify("Ошибка", "Сначала установите точки A и B", 3)
        return
    end
    if loopABActive then stopLoopAB() end
    loopABActive = true
    currentABTarget = "A"
    sendNotify("Цикл A-B", "Запущен (A → B → A ...)")
    loopABCoroutine = task.spawn(function()
        while loopABActive do
            if currentABTarget == "A" then
                teleport(pointA)
                currentABTarget = "B"
            else
                teleport(pointB)
                currentABTarget = "A"
            end
            task.wait(settings.loopDelay)
        end
    end)
end

-- ========== СПИСОК ИГРОКОВ ==========
local function getPlayerList()
    local names = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LP then
            table.insert(names, plr.Name)
        end
    end
    table.sort(names)
    if #names == 0 then names = {"(нет игроков)"} end
    return names
end

