-- ========== HUD ФУНКЦИИ ==========
local function createHUD()
    if hudFrame then hudFrame:Destroy() end
    if not showHUD then return end
    
    local screenGui = LP:FindFirstChild("TeleportHUD")
    if not screenGui then
        screenGui = Instance.new("ScreenGui")
        screenGui.Name = "TeleportHUD"
        screenGui.Parent = LP:WaitForChild("PlayerGui")
        screenGui.ResetOnSpawn = false
    end
    
    hudFrame = Instance.new("Frame")
    hudFrame.Name = "CoordFrame"
    hudFrame.Parent = screenGui
    hudFrame.Size = UDim2.new(0, 180, 0, 60)
    hudFrame.Position = UDim2.new(1, -190, 0, 10)
    hudFrame.BackgroundColor3 = hudBgColor
    hudFrame.BackgroundTransparency = hudTransparency
    hudFrame.BorderSizePixel = 1
    hudFrame.BorderColor3 = Color3.fromRGB(100, 100, 100)
    hudFrame.Active = true
    hudFrame.Draggable = true  -- можно перетаскивать мышкой
    Instance.new("UICorner", hudFrame).CornerRadius = UDim.new(0, 8)
    
    local title = Instance.new("TextLabel")
    title.Parent = hudFrame
    title.Size = UDim2.new(1, 0, 0, 20)
    title.BackgroundTransparency = 1
    title.Text = "📍 Текущие координаты"
    title.TextColor3 = Color3.fromRGB(200, 200, 200)
    title.TextSize = 12
    title.Font = Enum.Font.Gotham
    
    hudLabel = Instance.new("TextLabel")
    hudLabel.Parent = hudFrame
    hudLabel.Size = UDim2.new(1, 0, 0, 35)
    hudLabel.Position = UDim2.new(0, 0, 0, 22)
    hudLabel.BackgroundTransparency = 1
    hudLabel.Text = "X: 0\nY: 0\nZ: 0"
    hudLabel.TextColor3 = hudColor
    hudLabel.TextSize = 14
    hudLabel.Font = Enum.Font.GothamBold
    hudLabel.TextXAlignment = Enum.TextXAlignment.Center
end

local function updateHUD()
    if not showHUD or not hudLabel then return end
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        local pos = hrp.Position
        hudLabel.Text = string.format("X: %.0f\nY: %.0f\nZ: %.0f", pos.X, pos.Y, pos.Z)
    else
        hudLabel.Text = "X: ---\nY: ---\nZ: ---"
    end
end

local function destroyHUD()
    if hudFrame then hudFrame:Destroy(); hudFrame = nil end
    local screenGui = LP:FindFirstChild("TeleportHUD")
    if screenGui then screenGui:Destroy() end
end

local function toggleHUD(val)
    showHUD = val
    if showHUD then
        createHUD()
        updateHUD()
        -- запускаем обновление, если ещё не запущено
        if not _hudUpdateConn then
            _hudUpdateConn = RunService.Heartbeat:Connect(updateHUD)
        end
    else
        destroyHUD()
        if _hudUpdateConn then _hudUpdateConn:Disconnect(); _hudUpdateConn = nil end
    end
end

-- ========== ОСНОВНЫЕ ФУНКЦИИ ==========
local function playClickSound()
    if clickSoundEnabled and effectsEnabled then
        local sound = Instance.new("Sound")
        sound.SoundId = CLICK_SOUND_ID
        sound.Volume = 0.2 * effectIntensity
        sound.Parent = LP.Character or LP
        sound:Play()
        game:GetService("Debris"):AddItem(sound, 1)
    end
end

local function teleport(pos)
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    hrp.CFrame = CFrame.new(pos)
    
    if effectsEnabled then
        -- Звук Эндермена
        local sound = Instance.new("Sound")
        sound.SoundId = ENDERMAN_SOUND_ID
        sound.Volume = 0.5 * effectIntensity
        sound.Parent = hrp
        sound:Play()
        game:GetService("Debris"):AddItem(sound, 1)
        
        -- Частицы
        local particleEmitter = Instance.new("ParticleEmitter")
        particleEmitter.Parent = hrp
        particleEmitter.Rate = 300 * effectIntensity
        particleEmitter.Lifetime = NumberRange.new(0.6)
        particleEmitter.SpreadAngle = Vector2.new(360, 360)
        particleEmitter.Speed = NumberRange.new(8)
        particleEmitter.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.7),
            NumberSequenceKeypoint.new(1, 1),
        })
        particleEmitter.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(180, 80, 255)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(100, 0, 200)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(60, 0, 120)),
        })
        particleEmitter.Size = NumberSequence.new(1.5)
        particleEmitter.Rotation = NumberRange.new(0, 360)
        particleEmitter.Acceleration = Vector3.new(0, -5, 0)
        particleEmitter.Enabled = true
        task.wait(0.05)
        particleEmitter.Enabled = false
        game:GetService("Debris"):AddItem(particleEmitter, 1)
        
        -- Вспышка
        if effectIntensity > 0.5 then
            local flash = Instance.new("Frame")
            flash.Size = UDim2.new(2, 0, 2, 0)
            flash.Position = UDim2.new(-0.5, 0, -0.5, 0)
            flash.BackgroundColor3 = Color3.fromRGB(100, 0, 150)
            flash.BackgroundTransparency = 0.6
            flash.BorderSizePixel = 0
            local gui = LP:FindFirstChild("PlayerGui")
            if gui then
                flash.Parent = gui
                flash.ZIndex = 999
                TweenService:Create(flash, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
                game:GetService("Debris"):AddItem(flash, 0.3)
            end
        end
    end
end

local function sendNotify(title, content, duration, icon)
    Rayfield:Notify({
        Title = title,
        Content = content,
        Duration = duration or 2,
        Image = icon or 4483362458,
    })
end

local function autoNotify(msg)
    autoNotifyCounter = autoNotifyCounter + 1
    if autoNotifyCounter % 5 == 1 then
        sendNotify("Автоцикл", msg, 1)
    end
end

local function tpToCoords(x, y, z)
    x = tonumber(x) or 0
    y = tonumber(y) or 50
    z = tonumber(z) or 0
    lastCoords = {x = tostring(x), y = tostring(y), z = tostring(z)}
    teleport(Vector3.new(x, y, z))
    sendNotify("📍 Телепорт", string.format("(%.0f, %.0f, %.0f)", x, y, z), 1)
end

-- Дом
local function setHome()
    playClickSound()
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        homePos = hrp.Position
        sendNotify("🏠 Дом", string.format("Сохранён (%.0f, %.0f, %.0f)", homePos.X, homePos.Y, homePos.Z), 2)
    else
        sendNotify("❌ Ошибка", "Не удалось сохранить дом", 3)
    end
end

local function goHome()
    playClickSound()
    if homePos then
        teleport(homePos)
        sendNotify("🏠 Дом", "Возврат", 1)
    else
        sendNotify("⚠️ Ошибка", "Дом не установлен", 3)
    end
end

-- Автоцикл
local function randomPos()
    local x = math.random(settings.randXmin, settings.randXmax)
    local y = math.random(settings.randYmin, settings.randYmax)
    local z = math.random(settings.randZmin, settings.randZmax)
    return Vector3.new(x, y, z)
end

local stepCount = 0
local function autoStep()
    local target = randomPos()
    teleport(target)
    stepCount = stepCount + 1
    if settings.returnEvery > 0 and homePos and stepCount % settings.returnEvery == 0 then
        teleport(homePos)
        autoNotify("🏠 Возврат домой (шаг " .. stepCount .. ")")
    else
        autoNotify(string.format("Шаг #%d → (%.0f, %.0f, %.0f)", stepCount, target.X, target.Y, target.Z))
    end
end

local function startAuto()
    if autoActive then return end
    autoActive = true
    stepCount = 0
    autoNotifyCounter = 0
    sendNotify("🔄 Автоцикл", "Запущен", 1)
    autoCoroutine = task.spawn(function()
        while autoActive do
            autoStep()
            task.wait(settings.loopDelay)
        end
    end)
end

local function stopAuto()
    if not autoActive then return end
    autoActive = false
    if autoCoroutine then task.cancel(autoCoroutine); autoCoroutine = nil end
    sendNotify("🔄 Автоцикл", "Остановлен", 1)
end

-- Следование
local function stopFollow()
    if followActive then
        followActive = false
        if followCoroutine then task.cancel(followCoroutine); followCoroutine = nil end
        sendNotify("👥 Следование", "Остановлено", 1)
    end
end

local function startFollow()
    if selectedPlayer == "" or selectedPlayer == "(нет игроков)" then
        sendNotify("❌ Ошибка", "Сначала выберите игрока", 2)
        return
    end
    if followActive then stopFollow() end
    followActive = true
    sendNotify("👥 Следование", "Включено для " .. selectedPlayer, 1)
    followCoroutine = task.spawn(function()
        while followActive do
            local target = Players:FindFirstChild(selectedPlayer)
            if not target or not target.Character then
                sendNotify("👥 Следование", "Игрок покинул игру", 2)
                stopFollow()
                break
            end
            local hrp = target.Character:FindFirstChild("HumanoidRootPart")
            local hum = target.Character:FindFirstChildOfClass("Humanoid")
            if not hrp or not hum then
                task.wait(0.5)
                continue
            end
            if hum.Health <= 0 then
                sendNotify("👥 Следование", "Игрок умер, следование прекращено", 2)
                stopFollow()
                break
            end
            local pos = hrp.Position
            local offset = Vector3.new((math.random() - 0.5) * settings.followDistance, 0, (math.random() - 0.5) * settings.followDistance)
            teleport(pos + offset)
            task.wait(settings.followInterval)
        end
    end)
end

local function teleportToPlayerOnce()
    playClickSound()
    if selectedPlayer == "" or selectedPlayer == "(нет игроков)" then
        sendNotify("❌ Ошибка", "Нет выбранного игрока", 2)
        return
    end
    local target = Players:FindFirstChild(selectedPlayer)
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local pos = target.Character.HumanoidRootPart.Position
        local offset = Vector3.new(2, 0, 2)
        teleport(pos + offset)
        sendNotify("🎯 Телепорт", "К игроку " .. target.DisplayName, 1)
    else
        sendNotify("❌ Ошибка", "Игрок не найден или нет персонажа", 3)
    end
end

-- Цикл A-B
local function setPointA()
    playClickSound()
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        pointA = hrp.Position
        sendNotify("🔵 Цикл A-B", "Точка A сохранена", 1)
    else
        sendNotify("❌ Ошибка", "Не удалось сохранить точку A", 3)
    end
end

local function setPointB()
    playClickSound()
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        pointB = hrp.Position
        sendNotify("🔴 Цикл A-B", "Точка B сохранена", 1)
    else
        sendNotify("❌ Ошибка", "Не удалось сохранить точку B", 3)
    end
end

local function swapAB()
    playClickSound()
    if pointA and pointB then
        pointA, pointB = pointB, pointA
        sendNotify("🔄 Цикл A-B", "Точки A и B поменяны местами", 1)
    else
        sendNotify("⚠️ Ошибка", "Сначала установите обе точки", 2)
    end
end

local function stopLoopAB()
    if loopABActive then
        loopABActive = false
        if loopABCoroutine then task.cancel(loopABCoroutine); loopABCoroutine = nil end
        sendNotify("🔁 Цикл A-B", "Остановлен", 1)
    end
end

local function startLoopAB()
    playClickSound()
    if not pointA or not pointB then
        sendNotify("❌ Ошибка", "Сначала установите точки A и B", 3)
        return
    end
    if loopABActive then stopLoopAB() end
    loopABActive = true
    currentABTarget = "A"
    sendNotify("🔁 Цикл A-B", "Запущен (A → B → A ...)", 1)
    loopABCoroutine = task.spawn(function()
        while loopABActive do
            if currentABTarget == "A" then
                teleport(pointA)
                currentABTarget = "B"
            else
                teleport(pointB)
                currentABTarget = "A"
            end
            task.wait(settings.abLoopDelay)
        end
    end)
end

-- Копирование координат
local function copyCurrentCoords()
    playClickSound()
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        local pos = hrp.Position
        lastCoords = {x = tostring(math.floor(pos.X)), y = tostring(math.floor(pos.Y)), z = tostring(math.floor(pos.Z))}
        if Window.Flags then
            Window.Flags.tpX = lastCoords.x
            Window.Flags.tpY = lastCoords.y
            Window.Flags.tpZ = lastCoords.z
        end
        sendNotify("📋 Координаты", string.format("Скопированы: (%s, %s, %s)", lastCoords.x, lastCoords.y, lastCoords.z), 1)
    else
        sendNotify("❌ Ошибка", "Не удалось определить текущую позицию", 2)
    end
end

-- Стоп всё
local function stopAll()
    playClickSound()
    if autoActive then stopAuto() end
    if followActive then stopFollow() end
    if loopABActive then stopLoopAB() end
    sendNotify("🛑 Стоп всё", "Все активные режимы остановлены", 2)
end

-- Список игроков
local function getPlayerList()
    local names = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LP then
            table.insert(names, plr.Name)
        end
    end
    table.sort(names)
    if #names == 0 then names = {"(нет игроков)"} end
    return names
end

