local function addSlider(parent, name, minVal, maxVal, step, getter, setter, suffix)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -20, 0, 50)
    frame.BackgroundTransparency = 1
    frame.Parent = parent
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1,0,0,20)
    label.BackgroundTransparency = 1
    label.Text = name .. ": " .. tostring(getter()) .. (suffix or "")
    label.TextColor3 = Color3.fromRGB(220,220,220)
    label.Font = Enum.Font.Gotham
    label.TextXAlignment = Enum.TextXAlignment.Left
    local barBg = Instance.new("Frame", frame)
    barBg.Size = UDim2.new(1, -80, 0, 8)
    barBg.Position = UDim2.new(0,0,0,28)
    barBg.BackgroundColor3 = Color3.fromRGB(50,50,65)
    Instance.new("UICorner", barBg).CornerRadius = UDim.new(1,0)
    local bar = Instance.new("Frame", barBg)
    bar.Size = UDim2.new((getter()-minVal)/(maxVal-minVal), 0, 1, 0)
    bar.BackgroundColor3 = Color3.fromRGB(100,150,255)
    Instance.new("UICorner", bar).CornerRadius = UDim.new(1,0)
    local valueBox = Instance.new("TextBox", frame)
    valueBox.Size = UDim2.new(0,60,0,25)
    valueBox.Position = UDim2.new(1,-65,0,22)
    valueBox.Text = tostring(getter())
    valueBox.BackgroundColor3 = Color3.fromRGB(45,45,60)
    valueBox.TextColor3 = Color3.fromRGB(255,255,255)
    Instance.new("UICorner", valueBox).CornerRadius = UDim.new(0,6)
    local dragging = false
    local function updateValue(val)
        val = math.clamp(val, minVal, maxVal)
        local rounded = math.floor(val/step+0.5)*step
        if math.abs(rounded-val) < step/2 then val = rounded end
        if getter() == val then return end
        setter(val)
        label.Text = name .. ": " .. tostring(val) .. (suffix or "")
        valueBox.Text = tostring(val)
        bar.Size = UDim2.new((val-minVal)/(maxVal-minVal), 0, 1, 0)
        saveSettings()
    end
    barBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            local mouse = LP:GetMouse()
            local rel = (mouse.X - barBg.AbsolutePosition.X) / barBg.AbsoluteSize.X
            updateValue(minVal + rel * (maxVal-minVal))
        end
    end)
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local mouse = LP:GetMouse()
            local rel = (mouse.X - barBg.AbsolutePosition.X) / barBg.AbsoluteSize.X
            updateValue(minVal + rel * (maxVal-minVal))
        end
    end)
    valueBox.FocusLost:Connect(function()
        local val = tonumber(valueBox.Text)
        if val then updateValue(val) else updateValue(getter()) end
    end)
    return frame
end

