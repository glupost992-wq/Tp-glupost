        tpToCoords(x, y, z)
    end
})

tpTab:CreateKeybind({
    Name = "Установить дом",
    CurrentKeybind = "H",
    HoldToInteract = false,
    Flag = "setHomeBind",
    Callback = setHome
})

tpTab:CreateKeybind({
    Name = "Вернуться домой",
    CurrentKeybind = "G",
    HoldToInteract = false,
    Flag = "goHomeBind",
    Callback = goHome
})

-- ---- Вкладка "Автоцикл" ----
local autoTab = Window:CreateTab("Автоцикл", 4483362458)

autoTab:CreateToggle({
    Name = "Включить автоцикл",
    CurrentValue = false,
    Flag = "autoLoopEnabled",
    Callback = function(val)
        if val then startAuto() else stopAuto() end
    end
})

autoTab:CreateSlider({
    Name = "X минимальная",
    Range = {-10000, 10000},
    Increment = 10,
    CurrentValue = settings.randXmin,
    Flag = "randXmin",
    Callback = function(val) settings.randXmin = val end
})
autoTab:CreateSlider({
    Name = "X максимальная",
    Range = {-10000, 10000},
    Increment = 10,
    CurrentValue = settings.randXmax,
    Flag = "randXmax",
    Callback = function(val) settings.randXmax = val end
})

autoTab:CreateSlider({
    Name = "Y минимальная",
    Range = {0, 500},
    Increment = 5,
    CurrentValue = settings.randYmin,
    Flag = "randYmin",
    Callback = function(val) settings.randYmin = val end
})
autoTab:CreateSlider({
    Name = "Y максимальная",
    Range = {0, 500},
    Increment = 5,
    CurrentValue = settings.randYmax,
    Flag = "randYmax",
    Callback = function(val) settings.randYmax = val end
})

autoTab:CreateSlider({
    Name = "Z минимальная",
    Range = {-10000, 10000},
    Increment = 10,
    CurrentValue = settings.randZmin,
    Flag = "randZmin",
    Callback = function(val) settings.randZmin = val end
})
autoTab:CreateSlider({
    Name = "Z максимальная",
    Range = {-10000, 10000},
    Increment = 10,
    CurrentValue = settings.randZmax,
    Flag = "randZmax",
    Callback = function(val) settings.randZmax = val end
})

autoTab:CreateSlider({
    Name = "Задержка между телепортами (сек)",
    Range = {0.2, 10},
    Increment = 0.1,
    CurrentValue = settings.loopDelay,
    Flag = "loopDelay",
    Callback = function(val) settings.loopDelay = val end
})

autoTab:CreateInput({
    Name = "Возврат домой каждые N шагов (0 = отключить)",
    CurrentValue = tostring(settings.returnEvery),
    PlaceholderText = "число",
    Flag = "returnEvery",
    Callback = function(val)
        settings.returnEvery = tonumber(val) or 0
    end
})

-- ---- Вкладка "Игроки" ----
local playerTab = Window:CreateTab("Игроки", 4483362458)

local playerDropdown = playerTab:CreateDropdown({
    Name = "Выберите игрока",
    Values = getPlayerList(),
    CurrentOption = selectedPlayer,
    Flag = "targetPlayer",
    Callback = function(option)
        selectedPlayer = option
    end
})

playerTab:CreateButton({
    Name = "Обновить список",
    Callback = function()
        playerDropdown:Refresh(getPlayerList())
        if #getPlayerList() > 0 and selectedPlayer == "" then
            selectedPlayer = getPlayerList()[1]
            playerDropdown:SetValue(selectedPlayer)
        end
    end
})

playerTab:CreateKeybind({
    Name = "Телепорт к выбранному игроку",
    CurrentKeybind = "C",
    HoldToInteract = false,
    Flag = "tpPlayerBind",
    Callback = function()
        if selectedPlayer and selectedPlayer ~= "" and selectedPlayer ~= "(нет игроков)" then
            teleportToPlayer(selectedPlayer)
        else
            sendNotify("Ошибка", "Нет выбранного игрока", 2)
        end
    end
})

-- ---- Настройки интерфейса ----
local uiTab = Window:CreateTab("UI", 4483362458)
uiTab:CreateKeybind({
    Name = "Открыть меню",
    CurrentKeybind = "RightShift",
    HoldToInteract = false,
    Flag = "menuBind",
    Callback = function() end
})

-- ========== 5. ЗАГРУЗКА СОХРАНЁННЫХ НАСТРОЕК ==========
Rayfield:LoadConfiguration()

task.wait(0.5)
settings.randXmin = Window.Flags.randXmin or settings.randXmin
settings.randXmax = Window.Flags.randXmax or settings.randXmax
settings.randYmin = Window.Flags.randYmin or settings.randYmin
settings.randYmax = Window.Flags.randYmax or settings.randYmax
settings.randZmin = Window.Flags.randZmin or settings.randZmin
settings.randZmax = Window.Flags.randZmax or settings.randZmax
settings.loopDelay = Window.Flags.loopDelay or settings.loopDelay
settings.returnEvery = tonumber(Window.Flags.returnEvery) or settings.returnEvery
selectedPlayer = Window.Flags.targetPlayer or ""

if Window.Flags.autoLoopEnabled then
    startAuto()
end

sendNotify("Готово", "Телепорт-скрипт загружен. Меню: RightShift (по умолчанию)", 3)
