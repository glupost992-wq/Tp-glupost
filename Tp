end

-- ========== СТОП ВСЁ ==========
local function stopAll()
    local any = false
    if autoActive then stopAuto(true); any = true end
    if followActive then stopFollow(true); any = true end
    if loopABActive then stopLoopAB(true); any = true end
    if any then playEventStopSound() end
end

-- ========== HUD ==========
local function updateHUD()
    if not settings.showHUD or not hudLabel then return end
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        local p = hrp.Position
        hudLabel.Text = string.format("X: %.0f\nY: %.0f\nZ: %.0f", p.X, p.Y, p.Z)
    else
        hudLabel.Text = "X: ---\nY: ---\nZ: ---"
    end
end

